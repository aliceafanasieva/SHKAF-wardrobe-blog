<main class="page-content">
  <section class="article-detail">
    <a href="/blog?user={{ userEmail }}" class="go-back">&larr; go back</a>

    <div class="article-header">
      <h1 class="article-title">{{ blog.title }}</h1>

      <button class="favorite-btn" data-id="{{ blog.id }}">
        <svg width="28" height="28" class="heart-icon">
          <use href="#{% if favoriteIds contains blog.id %}icon-heart-full{% else %}icon-heart-empty{% endif %}"></use>
        </svg>
      </button>
    </div>

    <p class="article-category">#{{ blog.category }}</p>
    <p class="article-description">{{ blog.content }}</p>

    <div class="article-images">
      <img src="{{ blog['image-1'] }}" alt="{{ blog.title }}, afbeelding 1">
      {% if blog['image-2'] %}
        <img src="{{ blog['image-2'] }}" alt="{{ blog.title }}, afbeelding 2">
      {% endif %}
    </div>
  </section>
</main>
