<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="shortcut icon" href="/assets/logo/logo_red.svg">
    <script src="/js/script.js" defer></script>
  </head>
  <body class="auth-page">
    <header>
      <nav>
        <div class="navigation-logo" style="visibility: visible;">
          <img src="/assets/logo/logo_red.svg" alt="Logo" class="logo" width="48" height="48">
          <h1>SHKAF</h1>
        </div>
      </nav>
    </header>

    <main class="login-page">
      <form action="/register" method="POST" class="login-form">
        <h2 class="login-title">create account</h2>

        {% if errorMessage %}
          <p class="form-message error">{{ errorMessage }}</p>
        {% endif %}

        <label for="name" class="visually-hidden">name</label>
        <input type="text" id="name" name="name" placeholder="name" required>

        <label for="email" class="visually-hidden">email</label>
        <input type="email" id="email" name="email" placeholder="email" required>

        <label for="password" class="visually-hidden">password</label>
        <input type="password" id="password" name="password" placeholder="password" required>

        <button class="submit login" type="submit">CONTINUE</button>

        <p class="auth-switch">
          Already have an account?
          <a href="/login">Login</a>
        </p>
      </form>
    </main>

    <button class="btn-theme-change" type="button"></button>
  </body>
</html>
